# Base de datos (SQLite filename or PostgreSQL URL)
SQL_DATABASE=arcadia.db

# API URL (usualmente vacío en desarrollo)
VITE_API_URL=

# Supabase (cloud backend)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Frontend Supabase (VITE_ prefix expuesto al cliente)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API Key (visible en cliente - ¡cuidado!)
GEMINI_API_KEY=

# CORS origin for Express server
CORS_ORIGIN=http://localhost:3000
